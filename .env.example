# =============================================================================
# Songpa Tennis Court Scraper - Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
#   cp .env.example .env
# =============================================================================

# --- Slack Webhook ---
# 1. Go to https://api.slack.com/apps -> Create New App -> From scratch
# 2. Name: "테니스장 알림봇", Workspace: your workspace
# 3. Features -> Incoming Webhooks -> Activate
# 4. "Add New Webhook to Workspace" -> select channel -> Authorize
# 5. Copy the Webhook URL below
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/TXXXXXXXX/BXXXXXXXX/XXXXXXXXXXXXXXXXXXXXXXXX

# --- SPC Login Credentials ---
# spc.esongpa.or.kr login credentials
SPC_USER_ID=your_user_id
SPC_PASSWORD=your_password
