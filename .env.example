# =============================================================================
# Songpa Tennis Court Scraper - Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
#   cp .env.example .env
# =============================================================================

# --- Slack Bot (Socket Mode) ---
# 1. Go to https://api.slack.com/apps -> Create New App -> From scratch
# 2. Name: "테니스장 알림봇", Workspace: your workspace
# 3. Settings -> Socket Mode -> Enable Socket Mode -> Generate App Token (xapp-...)
# 4. OAuth & Permissions -> Bot Token Scopes:
#      chat:write, app_mentions:read, channels:history, channels:read
# 5. Install App -> Copy Bot User OAuth Token (xoxb-...)
# 6. Event Subscriptions -> Enable -> Subscribe to bot events:
#      app_mention, message.channels
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-token

# Channel ID for daily scheduled reports (right-click channel -> View channel details -> copy ID)
SLACK_CHANNEL_ID=C0XXXXXXXXX

# --- Slack Webhook (legacy, optional) ---
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/TXXXXXXXX/BXXXXXXXX/XXXXXXXXXXXXXXXXXXXXXXXX

# --- SPC Login Credentials ---
# spc.esongpa.or.kr login credentials
SPC_USER_ID=your_user_id
SPC_PASSWORD=your_password
